[Unit]
Description=Botd Phoenix Application
After=network.target postgresql.service

[Service]
Type=exec
User=botd
Group=botd
EnvironmentFile=/etc/botd.env
ExecStart=/opt/botd/current/bin/server
ExecStop=/opt/botd/current/bin/botd stop
Restart=on-failure
RestartSec=5
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
